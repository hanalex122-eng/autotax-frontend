{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://web-production-69a8.up.railway.app/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ]
}
